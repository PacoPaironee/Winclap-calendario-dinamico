# ─────────────────────────────────────────────────────────────
# Copiá este archivo como `.env` y completá los valores.
# El `.env` real NO se sube al repo (está en .gitignore).
# ─────────────────────────────────────────────────────────────

# Ruta al archivo JSON de la Service Account (la "cuenta robot" de Google).
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ID de la nómina (el código largo que está en la URL del Google Sheet:
# docs.google.com/spreadsheets/d/  ESTE_ES_EL_ID  /edit )
NOMINA_SHEET_ID=1NByTXTzBZOmn_QKGqMpIFijnmqpu662NaHFAe2hnqxU

# Nombre de la pestaña + rango donde está la nómina.
NOMINA_RANGE=Hoja1!A1:Z1000

# Zona horaria de los eventos (para que los "todo el día" caigan bien).
TIMEZONE=America/Argentina/Buenos_Aires

# IDs de los calendarios por clapbase.
# Se completan solos al correr `npm run calendars:init` (o pegás los que ya tengas).
CAL_BUENOS_AIRES=
CAL_MENDOZA=
CAL_CORDOBA=
CAL_COLOMBIA=
CAL_BRAZIL=
